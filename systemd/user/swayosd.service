[Unit]
Description=SwayOSD Volume and Backlight Watcher
After=graphical-session.target
# Ensure it starts after the SwayOSD server if you run that too
Wants=swayosd-server.service

[Service]
# Adjust this path if your script is located elsewhere
ExecStart=%h/system_scripts/swayosd/swayosd-watcher.sh
Restart=always
RestartSec=1

[Install]
WantedBy=graphical-session.target
